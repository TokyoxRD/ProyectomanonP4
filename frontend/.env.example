# Copia este archivo a .env en local. En Render, define las mismas variables en el panel del servicio Web.

PORT=3000
# URL pública del backend (en Render: https://TU-SERVICIO-BACKEND.onrender.com sin barra final)
API_URL=http://localhost:3001

# Cadena larga y aleatoria en producción (sesiones de usuario)
SESSION_SECRET=cambia_esto_por_un_secreto_largo_y_unico

# En Render el servicio suele inyectar NODE_ENV=production automáticamente si eliges entorno Production
# NODE_ENV=production
 