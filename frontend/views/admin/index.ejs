<%- include('../partials/navbar') %>

<div class="page-container">
  <div class="section-title mb-2"><span class="dot"></span>Panel de Administración</div>

  <!-- Stats globales -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-num"><%= stats.totalUsers || 0 %></div>
      <div class="stat-label">Usuarios registrados</div>
    </div>
    <div class="stat-card red">
      <div class="stat-num"><%= stats.totalRestaurants || 0 %></div>
      <div class="stat-label">Negocios activos</div>
    </div>
    <div class="stat-card">
      <div class="stat-num"><%= stats.totalOrders || 0 %></div>
      <div class="stat-label">Pedidos totales</div>
    </div>
    <div class="stat-card red">
      <div class="stat-num">$<%= (stats.totalRevenue || 0).toFixed(2) %></div>
      <div class="stat-label">Ingresos totales</div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab('tabUsers', this)">👥 Usuarios</button>
    <button class="tab-btn" onclick="switchTab('tabRestaurants', this)">🏪 Negocios</button>
    <button class="tab-btn" onclick="switchTab('tabOrders', this)">📦 Pedidos</button>
  </div>

  <!-- TAB: Usuarios -->
  <div class="tab-content active" id="tabUsers">
    <div class="card-poyos" style="overflow:hidden;">
      <table class="table-poyos">
        <thead>
          <tr><th>ID</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Registro</th><th>Acción</th></tr>
        </thead>
        <tbody>
          <% users.forEach(function(u) { %>
            <tr>
              <td><b>#<%= u.id %></b></td>
              <td><%= u.name %></td>
              <td class="text-sm text-gris"><%= u.email %></td>
              <td><span class="badge-role badge-<%= u.role %>"><%= u.role %></span></td>
              <td class="text-sm"><%= new Date(u.createdAt).toLocaleDateString('es') %></td>
              <td>
                <% if (u.email !== 'admin@poyos.com') { %>
                  <form action="/admin/users/delete/<%= u.id %>" method="POST"
                        onsubmit="return confirm('¿Eliminar usuario?')" style="display:inline;">
                    <button class="btn-rojo" style="padding:4px 10px; font-size:0.78rem;">🗑</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- TAB: Restaurantes -->
  <div class="tab-content" id="tabRestaurants">
    <% if (restaurants.length === 0) { %>
      <div class="empty-state"><div class="empty-icon">🏪</div><p>No hay negocios registrados.</p></div>
    <% } else { %>
      <div class="card-poyos" style="overflow:hidden;">
        <table class="table-poyos">
          <thead>
            <tr><th>Nombre</th><th>Dueño</th><th>Dirección</th><th>Platos</th><th>Acción</th></tr>
          </thead>
          <tbody>
            <% restaurants.forEach(function(r) { %>
              <tr>
                <td>
                  <div style="display:flex; align-items:center; gap:8px;">
                    <img src="<%= r.image ? '/uploads/' + r.image : '/images/restaurant_default.png' %>"
                         style="width:36px; height:36px; border-radius:4px; object-fit:cover;">
                    <b><%= r.name %></b>
                  </div>
                </td>
                <td class="text-sm"><%= r.User ? r.User.name : 'N/A' %></td>
                <td class="text-sm text-gris"><%= r.address %></td>
                <td><%= r.MenuItems ? r.MenuItems.length : 0 %></td>
                <td>
                  <form action="/admin/restaurants/delete/<%= r.id %>" method="POST"
                        onsubmit="return confirm('¿Eliminar este negocio?')" style="display:inline;">
                    <button class="btn-rojo" style="padding:4px 10px; font-size:0.78rem;">🗑</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- TAB: Pedidos -->
  <div class="tab-content" id="tabOrders">
    <% if (orders.length === 0) { %>
      <div class="empty-state"><div class="empty-icon">📦</div><p>No hay pedidos registrados.</p></div>
    <% } else { %>
      <div class="card-poyos" style="overflow:hidden;">
        <table class="table-poyos">
          <thead>
            <tr><th>#</th><th>Cliente</th><th>Restaurante</th><th>Total</th><th>Tiempo</th><th>Fecha</th><th>Estado</th></tr>
          </thead>
          <tbody>
            <% orders.forEach(function(o) { %>
              <tr>
                <td><b>#<%= o.id %></b></td>
                <td class="text-sm"><%= o.User ? o.User.name : 'N/A' %></td>
                <td class="text-sm"><%= o.Restaurant ? o.Restaurant.name : 'N/A' %></td>
                <td class="text-rojo fw-bold">$<%= parseFloat(o.total).toFixed(2) %></td>
                <td>⏱ <%= o.delivery_time %> min</td>
                <td class="text-sm"><%= new Date(o.createdAt).toLocaleDateString('es') %></td>
                <td><span class="badge-role badge-<%= o.status === 'entregado' ? 'entregado' : 'pendiente' %>"><%= o.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
function switchTab(id, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}
</script>

<%- include('../partials/footer') %>
  