<%- include('../partials/navbar') %>

<div class="page-container">
  <div class="section-title mb-2"><span class="dot"></span>
    <%= typeof item !== 'undefined' && item ? 'Editar plato' : 'Agregar plato al menú' %>
  </div>

  <div class="form-poyos" style="max-width:520px;">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert-form alert-error"><%= error %></div>
    <% } %>

    <form action="<%= typeof item !== 'undefined' && item ? '/business/menu/edit/' + item.id : '/business/menu/new' %>"
          method="POST" enctype="multipart/form-data">

      <div class="form-group">
        <label for="itemName">Nombre del plato</label>
        <input type="text" id="itemName" name="name" placeholder="Ej: Tenders x6"
               value="<%= typeof item !== 'undefined' && item ? item.name : '' %>" required>
      </div>

      <div class="form-group">
        <label for="itemCat">Categoría</label>
        <select id="itemCat" name="category" required>
          <option value="">Selecciona una categoría</option>
          <% const cats = ['Tenders','Pica Pollo','Sándwiches','Alitas','Combos','Extras','Bebidas']; %>
          <% cats.forEach(function(c) { %>
            <option value="<%= c %>" <%= (typeof item !== 'undefined' && item && item.category === c) ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="itemPrice">Precio ($)</label>
        <input type="number" id="itemPrice" name="price" placeholder="0.00" step="0.01" min="0"
               value="<%= typeof item !== 'undefined' && item ? item.price : '' %>" required>
      </div>

      <div class="form-group">
        <label for="itemDesc">Descripción</label>
        <textarea id="itemDesc" name="description" placeholder="Describe el plato..."><%= typeof item !== 'undefined' && item ? item.description : '' %></textarea>
      </div>

      <div class="form-group">
        <label for="itemImage">Foto del plato</label>
        <input type="file" id="itemImage" name="image" accept="image/*">
        <% if (typeof item !== 'undefined' && item && item.image) { %>
          <div class="mt-1">
            <img src="/uploads/<%= item.image %>" style="height:80px; border-radius:6px; object-fit:cover;">
            <span class="text-sm text-gris">Imagen actual</span>
          </div>
        <% } %>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn-rojo" style="flex:1; justify-content:center;">
          <%= typeof item !== 'undefined' && item ? '💾 Guardar cambios' : '+ Agregar plato' %>
        </button>
        <a href="/business/dashboard" class="btn-outline">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
  